<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.SetmealMapper">
    <update id="update" parameterType="com.sky.entity.Setmeal">
        update setmeal
        <set>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="price != null">
                price = #{price},
            </if>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="categoryId != null">
                category_id = #{categoryId},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="image != null">
                image = #{image},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
            <if test="updateUser != null">
                update_user = #{updateUser},
            </if>
        </set>
        where id = #{id}
    </update>
    <delete id="delete" parameterType="java.util.ArrayList">
        delete from setmeal where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <!--条件分页查询-->
    <select id="page" resultType="com.sky.entity.Setmeal" parameterType="com.sky.dto.SetmealPageQueryDTO">
        select s.* , c.name as categoryName from setmeal s left join category c on s.category_id = c.id
        <where>
            <if test="name != null and name != ''">
                name like concat('%',#{name},'%')
            </if>
            <if test="categoryId != null">
                and category_id = #{categoryId}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by update_time desc
    </select>

    <!-- 结果映射 -->
    <resultMap id="setmealVOResultMap" type="com.sky.vo.SetmealVO">
        <id property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="name" column="name"/>
        <result property="price" column="price"/>
        <result property="status" column="status"/>
        <result property="description" column="description"/>
        <result property="image" column="image"/>
        <result property="updateTime" column="update_time"/>
        <result property="categoryName" column="categoryName"/>
        <!-- 一对多映射 -->
        <collection property="setmealDishes" ofType="com.sky.entity.SetmealDish">
            <id property="id" column="sd_id"/>
            <result property="setmealId" column="sd_setmeal_id"/>
            <result property="dishId" column="sd_dish_id"/>
            <result property="name" column="sd_name"/>
            <result property="price" column="sd_price"/>
            <result property="copies" column="sd_copies"/>
        </collection>
    </resultMap>

    <select id="getById" resultMap="setmealVOResultMap" parameterType="java.lang.Long">
        select s.id,
               s.category_id,
               s.name,
               s.price,
               s.status,
               s.description,
               s.image,
               s.update_time,
               c.name        as categoryName,
               sd.id         as sd_id,
               sd.setmeal_id as sd_setmeal_id,
               sd.dish_id    as sd_dish_id,
               sd.name       as sd_name,
               sd.price      as sd_price,
               sd.copies     as sd_copies
        from setmeal s
                 left join category c on s.category_id = c.id
                 left join setmeal_dish sd on s.id = sd.setmeal_id
        where s.id = #{id}
    </select>
</mapper>